<http://turismo-semantico.es/ontologia> a owl:Ontology ;
    rdfs:label "TurismoSemántico Ontología"@es ;
    rdfs:comment "Ontología para la plataforma de turismo semántico de España"@es .

ts:Castillo a owl:Class ;
    rdfs:label "Castillo"@es ;
    rdfs:comment "Fortaleza o edificación militar histórica"@es ;
    rdfs:subClassOf ts:Destino .

ts:anioPatrimonio a owl:DatatypeProperty ;
    rdfs:label "anioPatrimonio"@es ;
    rdfs:comment "Año de declaración UNESCO"@es ;
    rdfs:domain ts:PatrimonioUNESCO ;
    rdfs:range xsd:gYear .

ts:descripcion a owl:DatatypeProperty ;
    rdfs:label "descripcion"@es ;
    rdfs:comment "Descripción del destino"@es ;
    rdfs:domain ts:Destino ;
    rdfs:range xsd:string .

ts:esInversaDe a owl:ObjectProperty ;
    rdfs:comment "Relación inversa"@es ;
    rdfs:domain ts:tienePatrimonio ;
    rdfs:range ts:estaEn .

ts:latitud a owl:DatatypeProperty ;
    rdfs:label "latitud"@es ;
    rdfs:comment "Latitud geográfica WGS84"@es ;
    rdfs:domain ts:Destino ;
    rdfs:range xsd:decimal .

ts:longitud a owl:DatatypeProperty ;
    rdfs:label "longitud"@es ;
    rdfs:comment "Longitud geográfica WGS84"@es ;
    rdfs:domain ts:Destino ;
    rdfs:range xsd:decimal .

ts:nombre a owl:DatatypeProperty ;
    rdfs:label "nombre"@es ;
    rdfs:comment "Nombre del destino"@es ;
    rdfs:domain ts:Destino ;
    rdfs:range xsd:string .

ts:temperatura a owl:DatatypeProperty ;
    rdfs:label "temperatura"@es ;
    rdfs:comment "Temperatura actual en grados Celsius"@es ;
    rdfs:domain ts:Destino ;
    rdfs:range xsd:decimal .

ts:tieneEvento a owl:ObjectProperty ;
    rdfs:comment "El destino acoge un evento"@es ;
    rdfs:domain ts:Destino ;
    rdfs:range ts:Evento .

ts:urlImagen a owl:DatatypeProperty ;
    rdfs:label "urlImagen"@es ;
    rdfs:comment "URL de imagen representativa"@es ;
    rdfs:domain ts:Destino ;
    rdfs:range xsd:anyURI .

ts:wikidataId a owl:DatatypeProperty ;
    rdfs:label "wikidataId"@es ;
    rdfs:comment "Identificador en Wikidata"@es ;
    rdfs:domain ts:Destino ;
    rdfs:range xsd:string .

ts:Evento a owl:Class ;
    rdfs:label "Evento"@es ;
    rdfs:comment "Acontecimiento cultural o turístico"@es .

ts:tienePatrimonio a owl:ObjectProperty ;
    rdfs:comment "La ciudad alberga un destino turístico"@es ;
    rdfs:domain ts:Ciudad ;
    rdfs:range ts:Destino ;
    owl:inverseOf ts:estaEn .

ts:Ciudad a owl:Class ;
    rdfs:label "Ciudad"@es ;
    rdfs:comment "Núcleo urbano de España"@es .

ts:estaEn a owl:ObjectProperty ;
    rdfs:comment "El destino se ubica en una ciudad"@es ;
    rdfs:domain ts:Destino ;
    rdfs:range ts:Ciudad .

ts:PatrimonioUNESCO a owl:Class ;
    rdfs:label "PatrimonioUNESCO"@es ;
    rdfs:comment "Sitio declarado Patrimonio de la Humanidad por la UNESCO"@es ;
    rdfs:subClassOf ts:Destino .

ts:Museo a owl:Class ;
    rdfs:label "Museo"@es ;
    rdfs:comment "Institución que conserva y expone colecciones de valor cultural"@es ;
    rdfs:subClassOf ts:Destino .

ts:Destino a owl:Class ;
    rdfs:label "Destino"@es ;
    rdfs:comment "Lugar turístico de España"@es .

